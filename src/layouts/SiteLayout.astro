---
import '../styles/site.css'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Marketing Home</title>
  </head>
  <body>
    <div id="app">
      <header class="sticky top-0 z-20 border-b border-gray-200/80 bg-white/80 backdrop-blur">
        <div class="mx-auto flex max-w-6xl items-center justify-between gap-6 px-6 py-4">
          <a href="/" class="flex items-center gap-3 text-gray-950">
            <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-gray-950 text-lg font-semibold text-white shadow-lg shadow-gray-900/20">M</span>
            <span class="font-pj text-lg font-semibold">Marketing Website</span>
          </a>
          <nav class="hidden items-center gap-6 text-sm text-gray-600 md:flex">
            <a href="/" class="transition hover:text-gray-950">Home</a>
            <a href="/about/" class="transition hover:text-gray-950">About</a>
            <a href="/features/" class="transition hover:text-gray-950">Features</a>
            <a href="/docs/" class="inline-flex items-center gap-2 rounded-full border border-gray-200 bg-white px-4 py-2 text-gray-950 shadow-sm transition hover:border-gray-300 hover:bg-gray-50">Docs</a>
          </nav>
        </div>
      </header>

      <slot />

      <footer class="border-t border-gray-200 bg-gray-950 text-gray-200">
        <div class="mx-auto grid max-w-6xl gap-10 px-6 py-12 md:grid-cols-3">
          <section class="space-y-4">
            <div class="flex items-center gap-3">
              <span class="flex h-10 w-10 items-center justify-center rounded-2xl bg-white/10 text-sm font-semibold text-white">RG</span>
              <p class="font-pj text-lg font-semibold text-white">Route Graph Probe</p>
            </div>
            <p class="max-w-sm text-sm leading-7 text-gray-400">
              This footer exists to make every website route share a richer layout graph, closer to the real
              project.
            </p>
          </section>

          <section class="space-y-3">
            <p class="text-sm font-semibold tracking-[0.2em] text-gray-500 uppercase">Website</p>
            <ul class="space-y-2 text-sm text-gray-400">
              <li><a href="/" class="transition hover:text-white">Landing page</a></li>
              <li><a href="/about/" class="transition hover:text-white">About</a></li>
              <li><a href="/features/" class="transition hover:text-white">Features</a></li>
            </ul>
          </section>

          <section class="space-y-3">
            <p class="text-sm font-semibold tracking-[0.2em] text-gray-500 uppercase">Docs</p>
            <ul class="space-y-2 text-sm text-gray-400">
              <li><a href="/docs/" class="transition hover:text-white">Documentation home</a></li>
              <li><a href="/docs/getting-started/" class="transition hover:text-white">Getting started</a></li>
            </ul>
          </section>
        </div>
      </footer>
    </div>
  </body>
</html>
