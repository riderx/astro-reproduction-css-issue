---
export const prerender = false

import SiteLayout from '../layouts/SiteLayout.astro'
---

<SiteLayout>
  <main class="mx-auto flex min-h-screen max-w-5xl flex-col gap-10 px-6 py-16 text-gray-900">
    <div class="space-y-4">
      <p class="font-pj text-sm font-semibold tracking-[0.2em] text-azure-500 uppercase">Website Route</p>
      <h1 class="font-pj text-5xl font-semibold tracking-tight text-balance">Tailwind marketing page at <code>/</code></h1>
      <p class="max-w-2xl text-lg leading-8 text-gray-600">
        This page should keep normal website styles. Starlight reset CSS should only affect <code>/docs</code>.
      </p>
      <a href="/docs/" class="inline-flex w-fit items-center rounded-full bg-gray-950 px-5 py-3 text-sm font-medium text-white transition hover:bg-gray-800">
        Open docs
      </a>
    </div>
    <section class="rounded-3xl border border-gray-200 bg-white p-8 shadow-sm shadow-gray-200/60">
      <p class="mb-4 text-sm text-gray-500">
        The elements below intentionally rely on browser defaults. If the Starlight reset leaks onto this page,
        the heading and paragraph margins collapse to <code>0px</code>.
      </p>

      <h1 id="native-heading">Plain H1 on the website route</h1>
      <p id="native-paragraph">This paragraph should keep browser default top and bottom margins.</p>
      <button id="native-button" type="button">Plain button</button>

      <pre id="debug-output" class="mt-6 overflow-x-auto rounded-2xl bg-slate-950 p-4 text-sm text-slate-100"></pre>
    </section>

    <article class="blog prose prose-slate max-w-none rounded-3xl border border-gray-200 bg-white p-8 shadow-sm shadow-gray-200/60">
      <h1>Hidden duplicate title</h1>
      <h2 class="font-pj">Typography probe</h2>
      <p>
        This section intentionally uses Tailwind Typography, shared theme tokens, and a site rule that references
        <code>--sl-color-hairline</code>.
      </p>
      <hr />
      <table>
        <thead>
          <tr>
            <th>Layer</th>
            <th>Expectation</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Website</td>
            <td>Should not inherit Starlight reset on <code>/</code>.</td>
          </tr>
          <tr>
            <td>Docs</td>
            <td>Should still load Starlight CSS on <code>/docs/</code>.</td>
          </tr>
        </tbody>
      </table>
    </article>
  </main>

  <script is:inline>
    const heading = document.getElementById('native-heading')
    const paragraph = document.getElementById('native-paragraph')
    const output = document.getElementById('debug-output')

    if (heading && paragraph && output) {
      const bodyStyles = getComputedStyle(document.body)
      const headingStyles = getComputedStyle(heading)
      const paragraphStyles = getComputedStyle(paragraph)

      output.textContent = JSON.stringify(
        {
          bodyFontFamily: bodyStyles.fontFamily,
          bodyBackgroundColor: bodyStyles.backgroundColor,
          headingMarginTop: headingStyles.marginTop,
          headingMarginBottom: headingStyles.marginBottom,
          paragraphMarginTop: paragraphStyles.marginTop,
          paragraphMarginBottom: paragraphStyles.marginBottom,
        },
        null,
        2,
      )
    }
  </script>
</SiteLayout>
