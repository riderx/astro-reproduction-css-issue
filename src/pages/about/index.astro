---
export const prerender = false

import SiteLayout from '../../../src/layouts/SiteLayout.astro'
---

<SiteLayout>
  <main class="mx-auto flex min-h-screen max-w-5xl flex-col gap-6 px-6 py-16 text-gray-900">
    <p class="font-pj text-sm font-semibold tracking-[0.2em] text-azure-500 uppercase">Website Route</p>
    <h1 class="font-pj text-5xl font-semibold tracking-tight">Nested about page</h1>
    <p class="max-w-2xl text-lg leading-8 text-gray-600">
      This route exists to reproduce how multiple website <code>index.astro</code> entries affect emitted CSS chunks.
    </p>
    <article class="blog prose prose-slate max-w-none rounded-3xl border border-gray-200 bg-white p-8 shadow-sm shadow-gray-200/60">
      <h1>Duplicate title</h1>
      <h2>Shared CSS probe</h2>
      <p>
        This nested route uses the same website theme tokens and prose helpers so the emitted CSS graph matches the
        real project more closely.
      </p>
      <hr />
    </article>
  </main>
</SiteLayout>
