---
export const prerender = false

import SiteLayout from '../../../src/layouts/SiteLayout.astro'
---

<SiteLayout>
  <main class="mx-auto flex min-h-screen max-w-5xl flex-col gap-6 px-6 py-16 text-slate-900">
    <p class="text-sm font-semibold tracking-[0.2em] text-sky-700 uppercase">Website Route</p>
    <h1 class="text-5xl font-semibold tracking-tight">Nested features page</h1>
    <p class="max-w-2xl text-lg leading-8 text-slate-600">
      If chunk naming changes here, the docs and website routes should start sharing a different CSS asset.
    </p>
  </main>
</SiteLayout>
